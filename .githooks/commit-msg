#!/bin/bash
# Commit-msg hook: emulates the /verify subagent directly.
#
# Loads .claude/VERIFY_INSTRUCTION.md as the system prompt, then hands
# the model the proposed commit message and staged diff as the user
# prompt. The model behaves as the hostile reviewer described in that
# file without going through the skill mechanism, the Skill tool, or
# the Agent-tool spawn ceremony — VERIFY_INSTRUCTION.md is the same
# operating manual the /verify subagent uses, so both invocation paths
# stay in lockstep automatically.
#
# Default-reject: only an explicit `VERDICT: LEGIT` allows the commit.
# A clarifying question, error, or any other non-verdict response is
# treated as rejection.
#
# Gated on .git/.AI_GUARD — contributors / CI / fresh clones without
# the marker get a no-op hook.
#
# Install: git config core.hooksPath .githooks
# Activate on this clone: touch .git/.AI_GUARD

COMMIT_MSG_FILE="$1"
[ -z "$COMMIT_MSG_FILE" ] && exit 0
[ ! -f "$COMMIT_MSG_FILE" ] && exit 0

# claude searches from cwd upward for .mcp.json. If git invokes us from
# anywhere other than the repo root (e.g. via `git -C`, rebase, or a
# script-driven commit) MCP servers don't load and the hostile reviewer
# loses access to mcp__ida_mcp__ida_decompile, then flags every IDA
# citation as UNVERIFIABLE. Force cwd to the repo root before any
# claude call.
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$REPO_ROOT" || exit 0

[ ! -f ".git/.AI_GUARD" ] && exit 0
[ ! -f ".claude/VERIFY_INSTRUCTION.md" ] && exit 0

MSG=$(cat "$COMMIT_MSG_FILE")

case "$MSG" in
    "Merge "*|"fixup! "*|"squash! "*|"Revert "*|"amend! "*) exit 0 ;;
esac

if ! command -v claude &>/dev/null; then
    exit 0
fi

if git diff --cached --quiet 2>/dev/null; then
    exit 0
fi

# Only fire on commits that touch source code (.cpp, .h) or README.md.
# Pure docs / config / hook / test-script commits pass through without
# audit — running the hostile reviewer on those wastes a model call and
# tends to generate noise findings (e.g. "FABRICATED IDA CITATION" on a
# README change that legitimately has no code citations).
TOUCHED_RELEVANT=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '\.(cpp|h)$|(^|/)README\.md$' | head -1)
if [ -z "$TOUCHED_RELEVANT" ]; then
    exit 0
fi

# Load the hostile-reviewer operating manual verbatim. This is the same
# file the /verify subagent reads on spawn, so the direct-invocation and
# Agent-tool paths share one source of truth — no awk surgery, no risk
# of section names drifting between SKILL.md and this hook.
SUBAGENT_RULES=$(cat .claude/VERIFY_INSTRUCTION.md)

DIFF=$(git diff --cached --no-color)

# Session resumption keyed on HEAD SHA. Repeated audits of the same
# prospective commit (same HEAD, edits between attempts) reuse the same
# claude session, so prior tool outputs (CLAUDE.md / agent_docs reads,
# IDA decompiles, codebase greps) carry over instead of being re-paid.
# Once a commit lands, HEAD moves, the SHA-derived UUID changes, and
# the next audit starts from a fresh session.
LAST_COMMIT=$(git rev-parse HEAD 2>/dev/null) || LAST_COMMIT="initial"
SESSION_UUID=$(printf '%s' "verify-hook-$LAST_COMMIT" \
    | sha256sum \
    | cut -c1-32 \
    | sed 's/\(........\)\(....\)\(....\)\(....\)\(.*\)/\1-\2-\3-\4-\5/')

# Build the user-prompt content once; pipe it into whichever invocation wins.
build_user_prompt() {
    printf 'PROPOSED COMMIT MESSAGE:\n%s\n\nSTAGED DIFF:\n%s\n' "$MSG" "$DIFF"
}

# Try resume first. claude prints "No conversation found with session
# ID: ..." and exits 0 when the session doesn't exist, so we capture
# stderr+stdout and grep for the sentinel.
VERDICT=$(build_user_prompt | claude -p \
    --resume "$SESSION_UUID" \
    --system-prompt "$SUBAGENT_RULES" \
    --allowed-tools "Read,Grep,Glob,Bash(git *),mcp__ida_mcp__*" \
    --model opus \
    --output-format text 2>&1)

# Session miss → create with this UUID and run for the first time.
if echo "$VERDICT" | grep -q "No conversation found with session ID"; then
    VERDICT=$(build_user_prompt | claude -p \
        --session-id "$SESSION_UUID" \
        --system-prompt "$SUBAGENT_RULES" \
        --allowed-tools "Read,Grep,Glob,Bash(git *),mcp__ida_mcp__*" \
        --model opus \
        --output-format text 2>/dev/null)
fi

# Per VERIFY_INSTRUCTION.md the verdict block is the END of the
# response, so the LAST `VERDICT:` line is the authoritative one.
# Earlier "VERDICT:" strings inside the SUMMARY would be quoted
# references to past verdicts. Strip markdown bold first so
# `**VERDICT: LEGIT...**` and similar wrappers don't break the match.
FINAL_VERDICT=$(echo "$VERDICT" \
    | sed 's/\*\*//g' \
    | grep -E 'VERDICT: (LEGIT|CRITICAL PROBLEM FOUND)' \
    | tail -1)

case "$FINAL_VERDICT" in
    *"VERDICT: CRITICAL"*)  ;;  # explicit reject — fall through to error block
    *"VERDICT: LEGIT"*)
        exit 0 ;;
esac

echo ""
echo "╔══════════════════════════════════════════════════════════════════╗"
echo "║              *** /verify FLAGGED THIS COMMIT ***                ║"
echo "╚══════════════════════════════════════════════════════════════════╝"
echo ""
if [ -n "$VERDICT" ]; then
    echo "$VERDICT"
else
    echo "(no verdict returned)"
fi
echo ""
exit 1
